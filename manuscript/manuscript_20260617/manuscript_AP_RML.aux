\@writefile{toc}{\contentsline {subsubsection}{\numberline {4.2.4}WKB versus direct density discretization on coarse trait grids}{16}{subsubsection.4.2.4}\protected@file@percent }
\newlabel{subsec:test_wkb_advantage_new}{{4.2.4}{16}{WKB versus direct density discretization on coarse trait grids}{subsubsection.4.2.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Comparison between the WKB formulation and direct density discretizations on coarse trait grids. From left to right, the mutation parameter decreases. All trait marginals are reconstructed using the same log-based postprocessing described in the text. The direct density solver requires increasingly fine trait grids to resolve the concentrated marginal, whereas the WKB formulation continues to capture the selected trait through the phase variable.}}{17}{figure.4}\protected@file@percent }
\newlabel{fig:wkb_vs_direct_coarse}{{4}{17}{Comparison between the WKB formulation and direct density discretizations on coarse trait grids. From left to right, the mutation parameter decreases. All trait marginals are reconstructed using the same log-based postprocessing described in the text. The direct density solver requires increasingly fine trait grids to resolve the concentrated marginal, whereas the WKB formulation continues to capture the selected trait through the phase variable}{figure.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Two-dimensional spatial experiment}{18}{subsection.4.3}\protected@file@percent }
\newlabel{subsec:test_2d_new}{{4.3}{18}{Two-dimensional spatial experiment}{subsection.4.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Efficiency comparison in terms of effective degrees of freedom. The direct density solver uses $N_{\rm  dof}^{\rm  dir}=(N_x+1)\cdot N_\theta ^{(n)}$, while the WKB formulation uses $N_{\rm  dof}^{\rm  WKB}=(N_x+1) \cdot N_\theta ^{(W)}+N_\theta ^{(u)}$. The dual-grid WKB runs use a fine phase grid and a coarser amplitude grid. The results show that the WKB formulation can achieve comparable or better peak diagnostics with much fewer degrees of freedom.}}{19}{figure.5}\protected@file@percent }
\newlabel{fig:wkb_accuracy}{{5}{19}{Efficiency comparison in terms of effective degrees of freedom. The direct density solver uses $N_{\rm dof}^{\rm dir}=(N_x+1)\cdot N_\theta ^{(n)}$, while the WKB formulation uses $N_{\rm dof}^{\rm WKB}=(N_x+1) \cdot N_\theta ^{(W)}+N_\theta ^{(u)}$. The dual-grid WKB runs use a fine phase grid and a coarser amplitude grid. The results show that the WKB formulation can achieve comparable or better peak diagnostics with much fewer degrees of freedom}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Time-step robustness for fixed trait resolution $N_\theta =64$. Left: WKB solver. Right: direct density solver. Blue circles denote stable computations, whereas red crosses denote unstable computations. The WKB formulation permits larger admissible time steps in the small-$\varepsilon $ regime.}}{19}{figure.6}\protected@file@percent }
\newlabel{tab:time_step_size}{{6}{19}{Time-step robustness for fixed trait resolution $N_\theta =64$. Left: WKB solver. Right: direct density solver. Blue circles denote stable computations, whereas red crosses denote unstable computations. The WKB formulation permits larger admissible time steps in the small-$\varepsilon $ regime}{figure.6}{}}
