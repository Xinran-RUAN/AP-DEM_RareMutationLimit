{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 1200
  /ImageMatrix [75 0 0 1200 0 0]
  /Width 75
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
