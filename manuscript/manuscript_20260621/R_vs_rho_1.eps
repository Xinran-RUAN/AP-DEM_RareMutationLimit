GS
[0.48 0 0 0.48 0 24] CT
[1 0 0 1 0 0] CT
N
0 -50 M
1875 -50 L
1875 1200 L
0 1200 L
0 -50 L
cp
clip
GS
0 0 translate
1800 1200 scale
%AXGBeginBitmap: java.awt.image.BufferedImage
{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceRGB setcolorspace
<<
  /ImageType 1
  /Decode [0 1 0 1 0 1]
  /DataSource Data
  /Height 1200
  /ImageMatrix [1800 0 0 1200 0 0]
  /Width 1800
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
